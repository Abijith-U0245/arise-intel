# A.R.I.S.E. – Academic Risk Intelligence & Success Engine
# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# API Configuration
# =============================================================================

# Base URL for the A.R.I.S.E. REST API
VITE_API_BASE_URL=https://api.arise-platform.edu/v1

# API key for authentication (get from your A.R.I.S.E. dashboard)
VITE_API_KEY=your-api-key-here

# =============================================================================
# Blockchain Configuration (Hyperledger Fabric)
# =============================================================================

# Blockchain network identifier
VITE_BLOCKCHAIN_NETWORK=hyperledger-fabric

# Channel name for academic records
VITE_BLOCKCHAIN_CHANNEL=arise-academic-records

# Chaincode name for student records
VITE_BLOCKCHAIN_CHAINCODE=studentRiskCC

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS region for services
VITE_AWS_REGION=us-east-1

# Cognito User Pool ID for authentication
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# Cognito Client ID
VITE_COGNITO_CLIENT_ID=your-cognito-client-id

# =============================================================================
# AI/ML Model Configuration
# =============================================================================

# SageMaker endpoint for risk prediction
VITE_SAGEMAKER_ENDPOINT=arise-risk-predictor-v1

# Model confidence threshold (0-1)
VITE_MODEL_CONFIDENCE_THRESHOLD=0.85

# =============================================================================
# Feature Flags
# =============================================================================

# Enable blockchain audit trail logging
VITE_ENABLE_BLOCKCHAIN_AUDIT=true

# Enable real-time WebSocket updates
VITE_ENABLE_REAL_TIME_UPDATES=true

# Use mock data instead of live API (for development)
VITE_MOCK_DATA_MODE=false

# Enable debug logging
VITE_DEBUG_MODE=false

# =============================================================================
# Analytics & Monitoring
# =============================================================================

# Application Insights / Analytics key
VITE_ANALYTICS_KEY=your-analytics-key

# Log level (debug, info, warn, error)
VITE_LOG_LEVEL=info

# =============================================================================
# Security
# =============================================================================

# Session timeout in minutes
VITE_SESSION_TIMEOUT=30

# Enable MFA for admin accounts
VITE_ENABLE_MFA=true

# Rate limiting (requests per minute)
VITE_RATE_LIMIT=100
